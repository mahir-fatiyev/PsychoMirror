def analyze_sentiment(text):
    """Simple rule-based sentiment analysis."""
    positive_words = ["happy", "great", "love", "good", "amazing", "awesome"]
    negative_words = ["sad", "bad", "hate", "angry", "terrible", "worst"]
    
    score = 0
    words = text.lower().split()
    
    for word in words:
        if word in positive_words:
            score += 1
        elif word in negative_words:
            score -= 1
            
    if score > 0:
        return "😊 Positive Outlook"
    elif score < 0:
        return "😔 Negative Outlook"
    else:
        return "😐 Neutral / Complex"
